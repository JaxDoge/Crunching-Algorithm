98. Validate Binary Search Tree

class TreeNode:
	def __init__(self, val = 0, left = None, right = None):
		self.val = val 
		self.left = left
		self.right = right


# Always maintain the correct upper and lower bounds of current node
class Solution:
    def isValidBST(self, root: Optional[TreeNode]) -> bool:
        def preorder(node, low, high):
            if not node:
                return True
            if node.val <= low or node.val >= high:
                return False
            return preorder(node.left, low, node.val) and preorder(node.right, node.val, high)
        
        return preorder(root, float('-inf'), float('inf'))
